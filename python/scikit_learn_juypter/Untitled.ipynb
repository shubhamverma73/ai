   "source": [
    "from sklearn.linear_model import LinearRegression\n",
    "import numpy as np\n",
    "\n",
    "# Training data\n",
    "X = np.array([[1], [2], [3], [4], [5]])\n",
    "y = np.array([10, 20, 30, 40, 50])\n",
    "\n",
    "# Model\n",
    "model = LinearRegression()\n",
    "\n",
    "# Training\n",
    "model.fit(X, y)\n",
    "\n",
    "# Prediction\n",
    "print(model.predict([[6]]))"
   ]
  },
